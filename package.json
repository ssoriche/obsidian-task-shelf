{
	"name": "obsidian-task-shelf",
	"version": "0.1.0",
	"description": "Quick-capture modal for creating TaskNotes-compatible task notes.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "bun esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && bun esbuild.config.mjs production",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"lint": "eslint .",
		"version": "bun version-bump.mjs && git add manifest.json versions.json",
		"test": "bun test tests/"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.0.0",
		"esbuild": "0.27.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"jiti": "2.6.1",
		"tslib": "2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.58.1"
	},
	"dependencies": {
		"chrono-node": "^2.9.0",
		"obsidian": "latest"
	}
